# Timezone
TZ=America/Los_Angeles

# Workspace source and mount
WORKSPACE_GIT_URL=git@github.com:treerao/rowan.git
WORKSPACE_BRANCH=main
WORKSPACE_DIR=/Users/rrao/rowan-workspace

# OpenClaw runtime
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONFIG_DIR=/Users/rrao/rowan-runtime/openclaw-config
OPENCLAW_STATE_DIR=/Users/rrao/rowan-runtime/openclaw-state
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# Provider keys
OPENAI_API_KEY=REPLACE_ME
ANTHROPIC_API_KEY=REPLACE_ME

# Slack channel keys
SLACK_BOT_TOKEN=REPLACE_ME
SLACK_APP_TOKEN=REPLACE_ME

# Cloudflare tunnel
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# Rowan web service
ROWAN_WEB_ALLOWLIST=apps,docs,reports
ROWAN_WEB_INDEX=/apps/tasks/
